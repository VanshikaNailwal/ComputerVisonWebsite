# ======================
# APP CONFIGURATION
# ======================

APP_NAME=HMEL Vision Platform

ENVIRONMENT=production





# ======================
# DATABASE
# ======================

DATABASE_URL=postgresql://username:password@localhost:5432/database_name



# ======================
# SECURITY / JWT
# ======================

SECRET_KEY=CHANGE_THIS_SECRET_KEY

ALGORITHM=HS256

ACCESS_TOKEN_EXPIRE_MINUTES=60





# ======================
# STORAGE
# ======================

STORAGE_PATH=storage

MODEL_PATH=storage/models

EVIDENCE_PATH=storage/evidence





# ======================
# AI CONFIGURATION
# ======================

CONFIDENCE_THRESHOLD=0.4

FRAME_SKIP=5

ALERT_COOLDOWN=20





# ======================
# FIRST TIME SUPER ADMIN
# ======================

SUPER_ADMIN_EMAIL=admin@company.com

SUPER_ADMIN_PASSWORD=ChangeMe@123

SUPER_ADMIN_NAME=System Administrator

SUPER_ADMIN_EMPLOYEE_ID=ADMIN001